#!/usr/bin/env bash
# kd-vault-init (E4, WP-17) — idempotent per-user vault bring-up, run AS the vault-owning user by
# kd-provision (runuser). Args: <vault_repo_url>. Three jobs, each fail-SAFE (never stops the box):
#   1. CLONE ~/Vault if absent (uses the user's own git credential helper — E1; a local/file remote
#      needs none, which is the gate path). Unreachable ⇒ log alert, leave for next boot to retry.
#   2. SEED the broadened .gitignore (per-device volatile Obsidian state must never sync — E4).
#   3. ASSERT the remote forbids history rewrite + branch deletion, and gate sync on it:
#        confirmed protected     → touch ~/.kd/vault-ready   (sync allowed)
#        unreachable / unproven  → remove ~/.kd/vault-ready + alert   (sync PAUSED, box serves)
#        AFFIRMATIVELY unprotected → same pause + a distinct "ruleset-absent" alert
#      vault-ready is re-evaluated every boot, so a transient outage self-heals with no human action;
#      the human stop-flag (~/.kd/vault-stop) is reserved for genuine danger (mass-delete/conflict).
set -u

REPO="${1:-}"
VAULT="${KD_VAULT_DIR:-$HOME/Vault}"
READY="${KD_VAULT_READY:-$HOME/.kd/vault-ready}"
GITIGNORE_SRC="${KD_VAULT_GITIGNORE_SRC:-/usr/libexec/kd/kd-vault-gitignore}"
LOG(){ echo "kd-vault-init[$(id -un)]: $*"; }
alert(){ LOG "ALERT: $*"; [ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ] && command -v notify-send >/dev/null 2>&1 \
             && notify-send -u critical "Knowledge vault" "$1" 2>/dev/null || true; }

[ -n "$REPO" ] || { LOG "no vault_repo — vault disabled (E2 degrade)"; exit 0; }
mkdir -p "$(dirname "$READY")" 2>/dev/null

# A local-path vault_repo (the gate's bare mirror, or a local deployment) is shared read-only across
# uids, so git's dubious-ownership guard would refuse it. The roster explicitly DESIGNATED this path
# as the vault source — the roster is the trust root — so trust exactly that path (scoped, not '*').
# Production URLs (https/ssh) never take this branch and are unaffected.
case "$REPO" in
    /*|file://*|./*|../*) git config --global --add safe.directory "${REPO#file://}" 2>/dev/null || true ;;
esac

# --- 1. clone if absent ---------------------------------------------------------------------------
if [ ! -d "$VAULT/.git" ]; then
    if git clone -q "$REPO" "$VAULT" 2>/dev/null; then
        LOG "cloned $VAULT"
    else
        rm -rf "$VAULT" 2>/dev/null || true          # no half-clone left behind
        rm -f "$READY" 2>/dev/null || true
        alert "Could not reach the vault repository — sync is paused. It will retry automatically."
        LOG "clone failed (unreachable?) — will retry next boot (fail-safe, box serves)"
        exit 0
    fi
fi
cd "$VAULT" || { LOG "cannot cd $VAULT"; exit 0; }
branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || echo main)"

# --- 2. seed the broadened .gitignore (append our block once; committed by the first sync) --------
if [ -r "$GITIGNORE_SRC" ] && ! grep -q 'knowledge-desktop vault' .gitignore 2>/dev/null; then
    printf '\n' >> .gitignore 2>/dev/null || true
    cat "$GITIGNORE_SRC" >> .gitignore 2>/dev/null || true
    LOG "seeded broadened .gitignore (per-device Obsidian state excluded)"
fi

# --- 3. assert remote protection, gate sync on it -------------------------------------------------
# returns 0 = confirmed protected; 1 = affirmatively unprotected; 2 = undeterminable/unreachable
assert_protected(){
    local url; url="$(git remote get-url origin 2>/dev/null)" || return 2
    case "$url" in
        # local / file remote (the gate mirror): read the bare repo's receive.* config directly
        file://*|/*|./*|../*)
            local bare="${url#file://}"
            [ -d "$bare" ] || return 2
            local nff del
            nff="$(git -C "$bare" config --bool receive.denyNonFastForwards 2>/dev/null)"
            del="$(git -C "$bare" config --bool receive.denyDeletes 2>/dev/null)"
            [ "$nff" = true ] && [ "$del" = true ] && return 0 || return 1 ;;
        # GitHub remote: a repo ruleset with non_fast_forward + deletion is the production control.
        https://github.com/*|git@github.com:*|ssh://git@github.com/*)
            command -v gh >/dev/null 2>&1 || return 2
            local slug; slug="$(printf '%s' "$url" | sed -E 's#(https://github.com/|git@github.com:|ssh://git@github.com/)##; s#\.git$##')"
            local rs; rs="$(gh api "repos/$slug/rulesets" --jq '[.[].type] | @csv' 2>/dev/null)" || return 2
            # ruleset endpoint reachable+authed; presence of both rule types = protected
            printf '%s' "$rs" | grep -q non_fast_forward && printf '%s' "$rs" | grep -q deletion && return 0 || return 1 ;;
        *) return 2 ;;
    esac
}

if assert_protected; then
    : > "$READY"
    LOG "remote protection CONFIRMED (no-rewrite + no-delete) — sync enabled (branch $branch)"
elif [ $? -eq 1 ]; then
    rm -f "$READY" 2>/dev/null || true
    alert "The vault repository is NOT protected against history rewrite/deletion — sync paused until it is. Enable the server ruleset."
    LOG "GUARD: remote AFFIRMATIVELY unprotected — sync disabled (vault-ready withheld)"
else
    rm -f "$READY" 2>/dev/null || true
    alert "Could not verify vault repository protection — sync paused, will retry automatically."
    LOG "remote protection UNVERIFIED (unreachable/unknown) — sync disabled this boot (fail-safe)"
fi
exit 0
