#!/usr/bin/env bash
# kd-health (DESIGN §6 [ADJ-6]; WP-07 v1) — the merged container health command, referenced by
# the WP-03 quadlets (HealthCmd=kd-health) and the .live-gate. TRUTHFUL (F2): a dead desktop
# stack is never healthy; a slow first boot reads as unhealthy only until init completes
# (HealthStartPeriod covers the window); it asserts REAL state, never a cached flag alone.
#
# The UNCONDITIONAL L1 health tier (WP-02 strict E2 — every boot is provisioned; the skeleton-mode
# skip is RETIRED with E6 R18):
#   1. init completed (the entrypoint's /run/kd/boot-ok, removed on TERM)
#   2. session manager alive (xrdp-sesman)
#   3. RDP front listener alive (xrdp) AND answering on loopback :3389
#   4. provisioning completed (/run/kd/provision-complete) — always, no roster ⇒ no boot (E2)
#   5. VNC door (WP-09): ≥1 x0vncserver alive AND a loopback RFB port answers (N5 real TCP answer)
# Later tiers per design: web deep-liveness (WP-10, its own kd-web-health), tailnet-tier listeners
# iff the tailnet iface exists (tailnet WP), `systemctl --failed` on L2 (WP-08).
set -u
fail(){ echo "kd-health: UNHEALTHY — $*"; exit 1; }

[ -f /run/kd/boot-ok ] || fail "init incomplete (no /run/kd/boot-ok)"
pgrep -x xrdp-sesman >/dev/null || fail "xrdp-sesman not running"
pgrep -x xrdp        >/dev/null || fail "xrdp not running"
# a real TCP answer on the loopback door, not just a process (N5)
timeout 3 bash -c 'exec 3<>/dev/tcp/127.0.0.1/3389' 2>/dev/null \
    || fail "no answer on loopback :3389"
# SSH terminal door (WP-13, A8): sshd alive + answering on loopback :22 (a real TCP answer, N5)
pgrep -x sshd >/dev/null || fail "sshd not running (A8 terminal door down)"
timeout 3 bash -c 'exec 3<>/dev/tcp/127.0.0.1/22' 2>/dev/null \
    || fail "no answer on loopback :22 (sshd)"
# provisioning ALWAYS completes (strict E2 — a rosterless boot never reaches here; it exits rc=3)
[ -f /run/kd/provision-complete ] || fail "provisioning never completed"
# VNC door (WP-09): a provisioned box has ≥1 prestarted session, so ≥1 x0vncserver must be alive
# AND its loopback RFB port must answer (N5 — a real TCP answer, not just a process).
pgrep -x x0vncserver >/dev/null || fail "no x0vncserver (VNC door down)"
vnc_ok=0
for port in $(seq 5900 5940); do
    timeout 1 bash -c "exec 3<>/dev/tcp/127.0.0.1/$port" 2>/dev/null && { vnc_ok=1; break; }
done
[ "$vnc_ok" = 1 ] || fail "no VNC loopback port (5900-5940) answering"
exit 0
