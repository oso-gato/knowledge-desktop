# knowledge-desktop — LINEAGE 1: XRDP / X11 / XFCE (DESIGN.md §1)
# WP-07 WALKING SKELETON: a real desktop image — XFCE rendered server-side by Xorg/xorgxrdp,
# served over RDP, sessions prestarted at boot from the roster (C3/A11 seed). Base is
# digest-pinned (N1); the digest is bumped by PR only.
#
# Package justifications (N2 — capability-relative minimalism, weak deps off):
#   xrdp                  the RDP door (0.10.6, class a; DESIGN §1 pin)
#   xorgxrdp-glamor       the Xorg xrdpdev driver WITH glamor — the entire L1 B4 mechanism
#                         (GPU when present, swrast when not) as one class-(a) artifact
#   xorg-x11-server-Xorg  the non-suid Xorg sesman spawns per session (/usr/libexec/Xorg)
#   mesa-dri-drivers      GL/DRI runtime for glamor + llvmpipe software fallback (V16)
#   xfce4-session xfwm4 xfce4-panel xfdesktop xfce4-settings xfconf thunar
#                         the owner-elected XFCE core set (§1 lineage mandate; B1 windowing/
#                         file-management/desktop)
#   xfce4-notifyd         notification daemon — E4's human-visible conflict stop needs one
#                         (challenge VST-#7)
#   dbus-daemon           per-session bus bound at the DESIGNED address $XDG_RUNTIME_DIR/bus
#                         (VST-#7 contract) — no systemd user manager exists on this
#                         bash-PID-1 lineage to provide it (design-reconcile note, WP-07 PR)
#   python3               kd-provision runtime (WP-06)
#   shadow-utils          useradd/usermod/chpasswd — provisioning (WP-06)
#   tigervnc-server-common vncpasswd — the A13 first-8 VNC derivation (WP-06)
#   tigervnc-x11-server   x0vncserver — the WP-09 VNC door (attaches to the session's Xorg,
#                         loopback + AlwaysShared). NB the Fedora package that ships x0vncserver
#                         is tigervnc-x11-server, NOT "tigervnc-server" (DESIGN §17 pkg name
#                         corrected empirically — repoquery --whatprovides */x0vncserver)
#   acl                   setfacl — the D4 shared-folder default ACL (WP-06)
#   procps-ng             pgrep — kd-health's process liveness (F2)
#   glibc-langpack-en     UTF-8 locale so the desktop and terminals render text correctly
ARG FEDORA_DIGEST=sha256:dde4f63cf8b0f57ffb62fe16b32ced482d17a9a0ea97f8f532caf387a108afc2
FROM registry.fedoraproject.org/fedora@${FEDORA_DIGEST}

# HEAVY/STABLE-EARLY (churn balance): the dnf layer
RUN dnf -y --setopt=install_weak_deps=False install \
        xrdp xorgxrdp-glamor xorg-x11-server-Xorg mesa-dri-drivers \
        xfce4-session xfwm4 xfce4-panel xfdesktop xfce4-settings xfconf thunar \
        xfce4-notifyd dbus-daemon \
        python3 shadow-utils tigervnc-server-common tigervnc-x11-server \
        acl procps-ng glibc-langpack-en \
        openssh-server mosh tmux \
        podman crun passt fuse-overlayfs \
    && dnf clean all
# WP-13 (A8 terminal door): openssh-server (key-only, config below) + mosh (roaming UDP) + tmux
# (the one persistent per-user session). git-core arrives with the toolset (WP-15).
# WP-16 (B3 nested rootless podman): podman + crun (OCI runtime) + passt/pasta (rootless net) +
# fuse-overlayfs (the PINNED mount program — determinism across host classes + the gate, [ADJ-12]).
# shadow-utils (already above) provides newuidmap/newgidmap for the per-user subuid bands
# kd-provision writes. Per-user storage.conf + graphroot on the /home volume are provisioned at boot.

# A8 door config: key-only least-privilege sshd + the tmux auto-attach profile (ssh AND mosh).
COPY lineage-xrdp/sshd-kd.conf /etc/ssh/sshd_config.d/10-kd.conf
COPY shared/kd-tmux.sh         /etc/profile.d/kd-tmux.sh
RUN chmod 0644 /etc/ssh/sshd_config.d/10-kd.conf /etc/profile.d/kd-tmux.sh \
    # fail-closed asserts (N4): the door is key-only and roots-out
    && grep -q '^PasswordAuthentication no' /etc/ssh/sshd_config.d/10-kd.conf \
    && grep -q '^PermitRootLogin no' /etc/ssh/sshd_config.d/10-kd.conf

# ================= TOOLSET (WP-15, B2) — the knowledge-work applications =====================
# Provenance-classed per the tool-install hierarchy (class-a Fedora / class-b vendor gpg repo /
# class-c pinned download; NEVER COPR/curl|sh). CHURN-LATER than the desktop base: these bump on
# the F3 cadence (Obsidian bump-PR, Claude `latest`), so a toolset change never rebuilds the
# stable Xorg/XFCE layer above.
#   firefox         browser (a)
#   ptyxis          the owner-selected terminal, made DEFAULT below (a)
#   code            VS Code (b, Microsoft repo)
#   1password/-cli  1Password GUI + CLI (b, vendor repo)
#   claude-code     the resident agent (b, Anthropic `latest`; DISABLE_UPDATES pins the binary to
#                   the dnf-managed one so `claude update` cannot plant a home-volume shadow that
#                   defeats provenance — [ADJ-16]; the shadow-binary probe asserts it at the gate)
#   Obsidian        vault editor (c: official tar.gz, version+sha256 EXACT-pinned, fail-closed)
COPY shared/toolset/vendor-repos.sh /usr/local/libexec/kd-vendor-repos.sh
RUN chmod 0755 /usr/local/libexec/kd-vendor-repos.sh && /usr/local/libexec/kd-vendor-repos.sh \
    && dnf -y --setopt=install_weak_deps=False install \
        firefox ptyxis code 1password 1password-cli claude-code \
    && dnf clean all \
    && rm -f /usr/local/libexec/kd-vendor-repos.sh

# Obsidian (class-c): the URL + sha256 are the pin; a hash mismatch FAILS the build (fail-closed).
ARG OBSIDIAN_VERSION=1.12.7
ARG OBSIDIAN_SHA256=fcbe08b111d9c1fdb09b9c08952b06e1c829c62163eba2584c4b4ec859be079d
ADD https://github.com/obsidianmd/obsidian-releases/releases/download/v${OBSIDIAN_VERSION}/obsidian-${OBSIDIAN_VERSION}.tar.gz /tmp/obsidian.tar.gz
RUN set -eo pipefail \
    && echo "${OBSIDIAN_SHA256}  /tmp/obsidian.tar.gz" | sha256sum -c - \
    && mkdir -p /opt/obsidian \
    && tar xzf /tmp/obsidian.tar.gz -C /opt/obsidian --strip-components=1 \
    && ln -sf /opt/obsidian/obsidian /usr/local/bin/obsidian \
    && rm -f /tmp/obsidian.tar.gz \
    && test -x /opt/obsidian/obsidian \
    # Obsidian's tarball ships chrome-sandbox 0755 (VS Code + 1Password ship 4755) — without the
    # setuid bit Electron cannot use the SUID sandbox and would need --no-sandbox (V23 forbids it
    # "surfaced, never silent"). Set it setuid-root to match, giving Obsidian the same sandbox path.
    && chmod 4755 /opt/obsidian/chrome-sandbox

# Toolset config: Ptyxis as the XFCE default terminal (exo helpers mechanism — challenge L1-#10,
# NOT xfconf); Claude Code update-lock (managed settings); the Obsidian launcher.
COPY shared/toolset/kd-ptyxis.desktop          /usr/share/xfce4/helpers/kd-ptyxis.desktop
COPY shared/toolset/helpers.rc                 /etc/xdg/xfce4/helpers.rc
COPY shared/toolset/claude-managed-settings.json /etc/claude-code/managed-settings.json
COPY shared/toolset/obsidian.desktop           /usr/share/applications/obsidian.desktop

# Build-time assertions (N4 — a missing tool FAILS the build, never ships a broken toolset claim):
RUN set -e \
    && for b in firefox ptyxis code 1password obsidian; do command -v "$b" >/dev/null || { echo "TOOLSET MISSING: $b"; exit 1; }; done \
    && command -v op >/dev/null || { echo "TOOLSET MISSING: 1password-cli (op)"; exit 1; } \
    && test -x /usr/bin/claude || { echo "TOOLSET MISSING: claude at /usr/bin (dnf-managed)"; exit 1; } \
    && grep -q '"DISABLE_UPDATES": *"1"' /etc/claude-code/managed-settings.json \
    && grep -q '^TerminalEmulator=kd-ptyxis' /etc/xdg/xfce4/helpers.rc \
    # every Electron app's SUID sandbox is setuid (V23: they start WITHOUT --no-sandbox) \
    && for s in /usr/share/code/chrome-sandbox /opt/1Password/chrome-sandbox /opt/obsidian/chrome-sandbox; do \
         [ -u "$s" ] || { echo "V23: $s is not setuid — Electron would need --no-sandbox"; exit 1; }; done \
    && echo "TOOLSET (B2) assembled: firefox ptyxis code 1password(+op) claude obsidian-${OBSIDIAN_VERSION}"

# Config deltas over the SHIPPED files — sed with hard asserts so a package update that
# moves a line FAILS the build instead of silently dropping a product delta (N4):
#   xrdp.ini   port -> loopback-first ([ADJ-8]; the tailnet listener is added by the async
#              doors work, never at boot — E2: the box serves with no tailnet at all)
#   xrdp.ini   autorun=Xorg (credentialed connects land straight in the one Xorg session)
#   sesman.ini DefaultWindowManager -> startwm-kd (the product session wrapper)
# Fedora's shipped sesman defaults ALREADY carry the design pins Policy=Default,
# KillDisconnected=false, DisconnectedTimeLimit=0 (verified empirically) — asserted, not sed.
RUN set -e; \
    grep -q '^port=3389$' /etc/xrdp/xrdp.ini; \
    sed -i 's|^port=3389$|port=tcp://127.0.0.1:3389|' /etc/xrdp/xrdp.ini; \
    grep -q '^autorun=$' /etc/xrdp/xrdp.ini; \
    sed -i 's|^autorun=$|autorun=Xorg|' /etc/xrdp/xrdp.ini; \
    grep -qE '^DefaultWindowManager=' /etc/xrdp/sesman.ini; \
    sed -i 's|^DefaultWindowManager=.*|DefaultWindowManager=/usr/libexec/kd/startwm-kd|' /etc/xrdp/sesman.ini; \
    grep -q '^Policy=Default' /etc/xrdp/sesman.ini; \
    grep -q '^KillDisconnected=false' /etc/xrdp/sesman.ini; \
    grep -q '^DisconnectedTimeLimit=0' /etc/xrdp/sesman.ini

# CHURN-LATE: repo-owned glue
COPY lineage-xrdp/xorg.conf         /etc/X11/xrdp/xorg.conf
COPY shared/entrypoint-l1.sh        /usr/local/bin/kd-entrypoint
COPY shared/kd-health               /usr/local/bin/kd-health
COPY shared/kd-provision            /usr/libexec/kd/kd-provision
COPY lineage-xrdp/kd-cred           /usr/libexec/kd/kd-cred
COPY lineage-xrdp/kd-session-enable /usr/libexec/kd/kd-session-enable
COPY lineage-xrdp/startwm-kd        /usr/libexec/kd/startwm-kd
COPY lineage-xrdp/doors-agent       /usr/libexec/kd/doors-agent
COPY gate/probe/kd-vnc-login        /usr/libexec/kd/kd-vnc-login
COPY gate/probe/kd-vnc-check        /usr/libexec/kd/kd-vnc-check
RUN chmod 0755 /usr/local/bin/kd-entrypoint /usr/local/bin/kd-health \
        /usr/libexec/kd/kd-provision /usr/libexec/kd/kd-cred \
        /usr/libexec/kd/kd-session-enable /usr/libexec/kd/startwm-kd \
        /usr/libexec/kd/doors-agent /usr/libexec/kd/kd-vnc-login /usr/libexec/kd/kd-vnc-check

ENTRYPOINT ["/usr/local/bin/kd-entrypoint"]
