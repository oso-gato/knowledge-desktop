# knowledge-desktop .live-gate — v0 (WP-01): the workload-shipped, self-describing live-gate spec.
# PARSED — NEVER SOURCED — by the host's live-gate (lg_load reads KEY=VALUE line by line; this file
# travels in the UNTRUSTED PR head). INERT KEY=VALUE pairs only; no cross-variable references;
# single-quote HEALTH/PROBE (their $() run later INSIDE the fenced candidate, never on the host).
#
# TWO LINEAGES, one repo (REQUIREMENTS §1 Mandate; DESIGN §0): separate BUILDS, so this is a
# MULTI-TARGET spec — the gate builds + live-runs + probes EACH target independently.
#   * xrdp (lineage-xrdp/Containerfile) — bash PID 1 (kd-entrypoint).
#   * grd  (lineage-grd/Containerfile)  — systemd PID 1.
# v0 asserts the honest minimum: each candidate BOOTS and reaches its truthful init-complete
# state (N4/N5 seed — no theater). xrdp: the boot marker exists only after init. grd: the bare
# systemd skeleton must reach a TERMINAL boot state (running OR degraded — see HEALTH_grd), not
# stay stuck in `starting`; WP-08 tightens it to `running`. WP-02 grows the fenced-headscale
# harness + probe catalog (DESIGN §7); each capability WP extends HEALTH/PROBE in its own PR.
# shellcheck disable=SC2034 # keys are read by the gate's external parser, never by this file

# Order: grd, xrdp, then web LAST — the verdict comment keeps a TAIL of the combined log, so the
# last-probed target's self-diagnosing output survives truncation (web is the one under active
# iteration in WP-10; grd + xrdp are already GREEN).
LIVE_GATE_TARGETS="grd xrdp web"

# ---- LINEAGE 1: xrdp ------------------------------------------------------------------------
# WP-07 v1 (the sanctioned same-PR capability extension, header rule above): the walking
# skeleton's truthful bar — kd-health asserts init-complete + sesman/xrdp ALIVE + a real TCP
# answer on the loopback RDP door (N5), replacing the v0 boot-ok flag check. The gate boots
# this candidate WITHOUT a roster → SKELETON MODE (disclosed: E6 R18, retired at WP-02). The
# full RDP round-trip (session attach + paint) is HOST-GATE tier and lands with the WP-02
# probe-container harness; the nested dev engine cannot run isolated X sessions, so it is NOT
# proven in-box (in-box = build + assembly + boot→kd-health, per shared/tests/kd-l1-skeleton.test.sh).
CFILE_xrdp="lineage-xrdp/Containerfile"
HEALTH_xrdp='kd-health'
# self-diagnosing (H4): a RED carries its own evidence — run/kd state, the daemon census, and
# whether the loopback door answers
PROBE_xrdp='kd-health || { echo "=run-kd="; ls -la /run/kd 2>&1; echo "=procs="; pgrep -l "xrdp|sesman|Xorg|xfce" 2>&1; echo "=door="; timeout 2 bash -c "exec 3<>/dev/tcp/127.0.0.1/3389" 2>/dev/null && echo open || echo closed; exit 1; }'
HEALTH_TRIES_xrdp="20"
HEALTH_SLEEP_xrdp="5"

# ---- LINEAGE 2: grd (systemd PID 1) ---------------------------------------------------------
CFILE_grd="lineage-grd/Containerfile"
# systemd-PID-1 needs a writable cgroup tree (--cgroupns=host + the rw mount) or it pins at
# `starting`. /dev/fuse mirrors the lineage's real run contract (nested rootless podman, B3).
# Cap add-backs on the gate's --cap-drop=ALL floor (all userns-scoped under the rootless engine,
# a subset of podman's own defaults): systemd-tmpfiles fchownat() on /run/utmp + the journal dirs
# needs CHOWN/FOWNER/FSETID/DAC_OVERRIDE; the manager signals services with KILL; SETUID/SETGID/
# SETPCAP cover User= service transitions the WP-08 stack will add. Kept as the standing
# systemd-PID-1 fence; the set is re-derived (and trimmed if evidence allows) as real services land.
FENCE_grd="--systemd=always --cgroupns=host -v /sys/fs/cgroup:/sys/fs/cgroup:rw --device /dev/fuse --cap-add SETUID --cap-add SETGID --cap-add SETPCAP --cap-add CHOWN --cap-add FOWNER --cap-add FSETID --cap-add DAC_OVERRIDE --cap-add KILL"
# SKELETON contract (N4-honest): the WP-01 grd image installs only systemd, so its claim is
# "systemd-PID-1 booted to a TERMINAL state", not "every unit is healthy". Accept running OR
# degraded (both mean the boot transaction completed; a bare skeleton's statically-wanted logind
# unit fails for lack of its WP-08 stack — expected, not a defect); REJECT starting/offline
# (genuinely stuck/broken → RED). WP-08 tightens this back to `running` when every unit must be healthy.
HEALTH_grd='s=$(systemctl is-system-running 2>/dev/null); [ "$s" = running ] || [ "$s" = degraded ]'
# SELF-DIAGNOSING probe (H4): same accept-set, but on failure prints its own evidence — the
# manager state, the STUCK JOBS (the answer to a `starting` pin), the failed units, and a journal
# tail — so a RED never reads blind.
PROBE_grd='s=$(systemctl is-system-running 2>/dev/null); { [ "$s" = running ] || [ "$s" = degraded ]; } || { echo "=state=$s"; echo "=jobs="; systemctl list-jobs --no-legend; echo "=failed="; systemctl --failed --no-legend; echo "=journal="; journalctl -b -p warning -n 25 --no-pager; exit 1; }'
# Poll budget 20×6 = 120s ≥ the gate's 90s health-start-period. Head b126468 proved the boot is
# ~60s on the shared-vCPU host: the health poll (then 15×4=60s) expired at `starting` while the
# PROBE — the same command, seconds later — PASSED. F2: a slow first boot is never falsely
# unhealthy; the budget must exceed the real first boot, and 60s did not.
HEALTH_TRIES_grd="20"
HEALTH_SLEEP_grd="6"

# ---- LINEAGE 3: web (the ONE public door; DESIGN §3, WP-10) ---------------------------------
# The Guacamole gateway: Caddy :443 -> Tomcat 9 (guacamole webapp) -> guacd (vendored FreeRDP
# 3.14). bash PID 1 (kd-entrypoint), like xrdp — no systemd, so NO fence caps needed (Caddy binds
# :443 as root PID 1; default podman caps suffice). Boots WITHOUT a roster -> SKELETON MODE: the
# gateway comes up with ZERO provisioned users (the schema's default guacadmin is disabled at
# boot, A12 fail-closed); per-user auth (kd-provision -> kd-web-sync) rides deploy. The gate's
# truthful bar is DEEP-LIVENESS (N5): an UNAUTHENTICATED API GET traverses the full chain
# Caddy(TLS) -> Tomcat -> webapp -> Postgres and returns 200, generating ZERO auth failures (so it
# never self-bans, A4/WD-#11). The live per-user TOTP round-trip (A3/A4/A11) is a MANUAL/browser
# tier above the gate (disclosed E6) — not asserted here.
CFILE_web="lineage-web/Containerfile"
# Cap add-backs over the gate's --cap-drop=ALL floor (all userns-scoped, a subset of podman's own
# defaults — the same discipline as FENCE_grd). The web door is bash-PID-1 (NO systemd), so it needs
# NONE of grd's cgroup/systemd fence — only the caps its services genuinely use:
#   SETUID/SETGID/SETPCAP  runuser drops root→kdweb (postgres REFUSES to run as root; guacd + Tomcat
#                          also run as kdweb)
#   CHOWN                  the entrypoint mkdirs /run/postgresql (postgres' socket dir, absent
#                          without systemd-tmpfiles) and chowns it to kdweb
#   NET_BIND_SERVICE       Caddy (root) binds the :443 public door (A2) — a privileged port
# NB: DAC_OVERRIDE is deliberately NOT added — it is ineffective for cross-uid writes in the rootless
# userns (verified), so every file write is instead done AS its owner (kdweb), needing no cap.
FENCE_web="--cap-add SETUID --cap-add SETGID --cap-add SETPCAP --cap-add CHOWN --cap-add NET_BIND_SERVICE"
HEALTH_web='kd-health'
# self-diagnosing (H4): a RED carries its own evidence — boot markers, the service census, guacd's
# loopback door, and the deep-liveness HTTP code with the service logs that explain a non-200.
PROBE_web='kd-health || { echo "=run-kd="; ls -la /run/kd 2>&1; echo "=procs="; pgrep -l "guacd|java|caddy|postgres" 2>&1; echo "=guacd-door="; timeout 2 bash -c "exec 3<>/dev/tcp/127.0.0.1/4822" 2>/dev/null && echo open || echo closed; echo "=deep="; curl -sS -k -o /dev/null -w "%{http_code}\n" https://127.0.0.1:443/guacamole/api/languages 2>&1; echo "=tomcat-tail="; tail -15 /run/kd/tomcat.log 2>&1; echo "=guacd-tail="; tail -8 /run/kd/guacd.log 2>&1; exit 1; }'
# First boot runs initdb + guac schema load + Tomcat webapp expansion (genuinely slow on the
# shared-vCPU host): 30×6 = 180s budget, well past the ~60-90s real first boot (F2 — a slow first
# boot must never read as unhealthy; the grd lesson: budget must exceed the real first boot).
HEALTH_TRIES_web="30"
HEALTH_SLEEP_web="6"
