# knowledge-desktop .live-gate — v0 (WP-01): the workload-shipped, self-describing live-gate spec.
# PARSED — NEVER SOURCED — by the host's live-gate (lg_load reads KEY=VALUE line by line; this file
# travels in the UNTRUSTED PR head). INERT KEY=VALUE pairs only; no cross-variable references;
# single-quote HEALTH/PROBE (their $() run later INSIDE the fenced candidate, never on the host).
#
# TWO LINEAGES, one repo (REQUIREMENTS §1 Mandate; DESIGN §0): separate BUILDS, so this is a
# MULTI-TARGET spec — the gate builds + live-runs + probes EACH target independently.
#   * xrdp (lineage-xrdp/Containerfile) — bash PID 1 (kd-entrypoint).
#   * grd  (lineage-grd/Containerfile)  — systemd PID 1.
# v0 asserts the honest minimum: each candidate BOOTS and reaches its truthful init-complete
# state (N4/N5 seed — no theater: the marker exists only after init, systemd must reach
# `running`, not `degraded`). WP-02 grows the fenced-headscale harness + the probe catalog
# (DESIGN §7); each capability WP extends HEALTH/PROBE in the same PR that lands the capability.
# shellcheck disable=SC2034 # keys are read by the gate's external parser, never by this file

LIVE_GATE_TARGETS="xrdp grd"

# ---- LINEAGE 1: xrdp ------------------------------------------------------------------------
CFILE_xrdp="lineage-xrdp/Containerfile"
HEALTH_xrdp='test -f /run/kd/boot-ok'
PROBE_xrdp='test -f /run/kd/boot-ok'
HEALTH_TRIES_xrdp="10"
HEALTH_SLEEP_xrdp="3"

# ---- LINEAGE 2: grd (systemd PID 1) ---------------------------------------------------------
CFILE_grd="lineage-grd/Containerfile"
# The documented systemd-PID-1 fence from the gate's own schema reference
# (fedora-bootstrap/validation/live-gate.sample): without --cgroupns=host + a writable
# /sys/fs/cgroup, PID-1 systemd cannot finish setting up its cgroup hierarchy and the manager
# pins in `starting` forever — exactly the two RED signatures on this PR (unchanged by the
# dbus-broker fix, which is kept: logind is load-bearing for this lineage). /dev/fuse rides
# along because the lineage's REAL run contract carries it (nested rootless podman, B3/WP-03),
# and the fence mirrors the run contract minus publish/secrets.
FENCE_grd="--systemd=always --cgroupns=host -v /sys/fs/cgroup:/sys/fs/cgroup:rw --device /dev/fuse"
# `--quiet` exits 0 ONLY on `running` — a degraded (failed-unit) skeleton is RED, not green.
HEALTH_grd='systemctl is-system-running --quiet'
# SELF-DIAGNOSING probe (H4): the gate prints probe stdout on failure, so a RED carries its own
# evidence — the manager state, the STUCK JOBS (the answer to a `starting` pin), the failed
# units, and a journal tail. Quiet + exit 0 on success (identical gate semantics to v0).
PROBE_grd='systemctl is-system-running --quiet || { echo "=state="; systemctl is-system-running; echo "=jobs="; systemctl list-jobs --no-legend; echo "=failed="; systemctl --failed --no-legend; echo "=journal="; journalctl -b -p warning -n 25 --no-pager; exit 1; }'
# Poll budget 20×6 = 120s ≥ the gate's 90s health-start-period. Head b126468 proved the boot is
# ~60s on the shared-vCPU host: the health poll (then 15×4=60s) expired at `starting` while the
# PROBE — the same command, seconds later — PASSED. F2: a slow first boot is never falsely
# unhealthy; the budget must exceed the real first boot, and 60s did not.
HEALTH_TRIES_grd="20"
HEALTH_SLEEP_grd="6"
