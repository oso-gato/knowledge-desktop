# knowledge-desktop .live-gate — v0 (WP-01): the workload-shipped, self-describing live-gate spec.
# PARSED — NEVER SOURCED — by the host's live-gate (lg_load reads KEY=VALUE line by line; this file
# travels in the UNTRUSTED PR head). INERT KEY=VALUE pairs only; no cross-variable references;
# single-quote HEALTH/PROBE (their $() run later INSIDE the fenced candidate, never on the host).
#
# TWO LINEAGES, one repo (REQUIREMENTS §1 Mandate; DESIGN §0): separate BUILDS, so this is a
# MULTI-TARGET spec — the gate builds + live-runs + probes EACH target independently.
#   * xrdp (lineage-xrdp/Containerfile) — bash PID 1 (kd-entrypoint).
#   * grd  (lineage-grd/Containerfile)  — systemd PID 1.
# v0 asserts the honest minimum: each candidate BOOTS and reaches its truthful init-complete
# state (N4/N5 seed — no theater). xrdp: the boot marker exists only after init. grd: the bare
# systemd skeleton must reach a TERMINAL boot state (running OR degraded — see HEALTH_grd), not
# stay stuck in `starting`; WP-08 tightens it to `running`. WP-02 grows the fenced-headscale
# harness + probe catalog (DESIGN §7); each capability WP extends HEALTH/PROBE in its own PR.
# shellcheck disable=SC2034 # keys are read by the gate's external parser, never by this file

# WP-02 v1: xrdp + web now boot a REAL PROVISIONED box (roster-mixed.json rides SECRET_ENV →
# /run/secrets/kd-roster). STRICT E2 — a rosterless boot is a RED (skeleton mode retired, E6 R18
# deleted); the negative-secrets/admin-only/bad-admin RUNS land as sibling targets in PR 3. grd
# stays a bare systemd skeleton until WP-08. Order: grd, xrdp, web LAST (the verdict TAIL keeps the
# last target's self-diagnosis).
# Order: the verdict TAIL keeps the LAST target's self-diagnosis, so the CHURN target goes LAST —
# WP-08 makes that grd (the first #23 RED proved it: grd's failure was drowned by web's GREEN tail).
LIVE_GATE_TARGETS="grdgeom"
# ^ SPIKE-TRANSIENT (WP-12 V2 gate-keeper): only the grdgeom target runs on this draft PR — a focused
# GO/NO-GO for "can Mutter ApplyMonitorsConfig force the governing display's geometry across grd
# virtual monitors (C4-concurrent on the PRIMARY lineage)?". V3 already recorded (gate/spikes/
# FINDINGS.md). Production targets ("xrdp web grd") ride the feature PRs; restore before the WP-12 PR.

# ---- LINEAGE 1: xrdp (WP-02: real-roster provisioned boot + per-user identity proof) ----
CFILE_xrdp="lineage-xrdp/Containerfile"
# WP-02 v1: the gate boots a REAL provisioned box — roster-mixed.json rides SECRET_ENV (inlined
# into a 0600 host tempfile bind-mounted ro at SECRET_MOUNT); strict E2 means a rosterless boot is
# a RED (the xrdp_negsec run, PR 3, asserts that). PROBE proves per-user identity end to end:
# the exact census kadm/gw1/gw2 (5 value-free D6 exclusions absent) + a REAL VNC login round-trip
# via kd-vnc-check (A13/V8: good phrase + its first-8 truncation ACCEPT; a cross-user phrase +
# garbage CLEAN-REJECT, rc-exact so a conn error never passes). The inline roster MUST byte-equal
# gate/fixtures/roster-mixed.json — gate/lint.sh enforces it (single source of truth).
SECRET_MOUNT_xrdp="/run/secrets/kd-roster"
SECRET_ENV_xrdp='{"version":1,"box":{"tailnet_authkey":"tskey-fixture-not-a-real-key","endpoints":{"erebus":{"host":"erebus.tail.fixture","port":22,"user":"core"},"fedora-dev":{"host":"fedora-dev.tail.fixture","port":22,"user":"core"}},"shared_folder":true},"admin":{"username":"kadm","password":"adm-aaaa-0000","ssh_authorized_keys":["ssh-ed25519 AAAAfixtureKEYadm fixture@kd"],"tiles":["erebus","fedora-dev"]},"workers":[{"username":"gw1","password":"gw1-bbbb-1111","ssh_authorized_keys":["ssh-ed25519 AAAAfixtureKEYgw1 fixture@kd"],"tiles":["erebus"]},{"username":"gw2","password":"gw2-cccc-2222"},{"username":"gw3","password":"not-the-a13-shape-at-all"},{"username":"gw1","password":"dup-dddd-3333"},{"username":"root","password":"sys-eeee-4444"},{"username":"gw4","password":"gw4-ffff-5555","color":"mauve"},{"username":"gw5","password":"gw5-gggg-6666","tiles":["mars"]}]}'
# --security-opt label=disable: mirrors the production quadlet's SecurityLabelDisable=true (the real
# container runs SELinux-unconfined for nested rootless podman + passed devices, E6 R12). On a
# SELinux-ENFORCING gate host (erebus) the ro bind-mounted roster secret carries a host label the
# confined candidate cannot read (root gets EACCES on a root-owned 0600 file — the SELinux
# signature; unreproducible on the dev box, whose container has SELinux disabled). label=disable
# makes the candidate match its production posture and read the roster. The fence validator
# allowlists exactly this security-opt (never seccomp/apparmor=unconfined).
# provisioned boot ALSO needs the shadow-utils/session caps over the gate --cap-drop=ALL floor
# (runtime useradd/chpasswd + XFCE prestart; the web door needed the same set) + headroom: 4g /
# 2048 pids / 30x6s = 180s past the real first boot. NET_BIND_SERVICE added for the WP-13 sshd
# door (binds the PRIVILEGED :22; the older xrdp/VNC doors are >1024, so this is new), and
# SYS_CHROOT for the same door: sshd's pre-auth privilege separation chroot()s to
# /usr/share/empty.sshd — without it sshd answers :22 but EVERY login dies pre-auth.
FENCE_xrdp="--security-opt label=disable --cap-add SETUID --cap-add SETGID --cap-add SETPCAP --cap-add CHOWN --cap-add FOWNER --cap-add FSETID --cap-add DAC_OVERRIDE --cap-add KILL --cap-add NET_BIND_SERVICE --cap-add SYS_CHROOT"
MEMORY_xrdp="4g"
PIDS_xrdp="2048"
HEALTH_xrdp='kd-health'
PROBE_xrdp='kd-health && test $(id -u kadm) = 2000 && test $(id -u gw1) = 2001 && test $(id -u gw2) = 2002 && ! id -u gw3 2>/dev/null && ! id -u gw4 2>/dev/null && ! id -u gw5 2>/dev/null && /usr/libexec/kd/kd-vnc-check 5901 gw1-bbbb-1111 gw2-cccc-2222 && /usr/libexec/kd/kd-vnc-check 5900 adm-aaaa-0000 gw1-bbbb-1111 || { echo =run-kd: ; ls -la /run/kd 2>&1 ; echo =users: ; getent passwd | grep -E kadm..gw. 2>&1 ; echo =vnc-doors: ; for p in 5900 5901 5902 ; do timeout 1 bash -c "exec 3<>/dev/tcp/127.0.0.1/$p" 2>/dev/null && echo vnc $p open ; done ; echo =procs: ; pgrep -l xrdp.sesman.Xorg.xfce.x0vnc 2>&1 ; exit 1 ; }'
HEALTH_TRIES_xrdp="30"
HEALTH_SLEEP_xrdp="6"

# ---- LINEAGE 2: grd (systemd PID 1; WP-08: the REAL headless-GNOME walking skeleton) --------
CFILE_grd="lineage-grd/Containerfile"
# WP-08: the gate boots a REAL PROVISIONED L2 box — the same roster fixture as xrdp/web rides
# SECRET_ENV → /run/secrets/kd-roster (strict E2: rosterless boot ⇒ kd-provision exit-force ⇒
# container dies ⇒ RED, V19). The inline roster MUST byte-equal gate/fixtures/roster-mixed.json
# (gate/lint.sh enforces JSON-equality — single source of truth, identical to SECRET_ENV_xrdp).
SECRET_MOUNT_grd="/run/secrets/kd-roster"
SECRET_ENV_grd='{"version":1,"box":{"tailnet_authkey":"tskey-fixture-not-a-real-key","endpoints":{"erebus":{"host":"erebus.tail.fixture","port":22,"user":"core"},"fedora-dev":{"host":"fedora-dev.tail.fixture","port":22,"user":"core"}},"shared_folder":true},"admin":{"username":"kadm","password":"adm-aaaa-0000","ssh_authorized_keys":["ssh-ed25519 AAAAfixtureKEYadm fixture@kd"],"tiles":["erebus","fedora-dev"]},"workers":[{"username":"gw1","password":"gw1-bbbb-1111","ssh_authorized_keys":["ssh-ed25519 AAAAfixtureKEYgw1 fixture@kd"],"tiles":["erebus"]},{"username":"gw2","password":"gw2-cccc-2222"},{"username":"gw3","password":"not-the-a13-shape-at-all"},{"username":"gw1","password":"dup-dddd-3333"},{"username":"root","password":"sys-eeee-4444"},{"username":"gw4","password":"gw4-ffff-5555","color":"mauve"},{"username":"gw5","password":"gw5-gggg-6666","tiles":["mars"]}]}'
# systemd-PID-1 needs a writable cgroup tree (--cgroupns=host + the rw mount) or it pins at
# `starting`. /dev/fuse mirrors the lineage's real run contract (nested rootless podman, B3).
# Cap add-backs on the gate's --cap-drop=ALL floor (all userns-scoped under the rootless engine):
# systemd-tmpfiles + journal chowns need CHOWN/FOWNER/FSETID/DAC_OVERRIDE; the manager signals
# with KILL; SETUID/SETGID/SETPCAP cover User= transitions (now real: per-user managers + runuser
# provisioning). WP-08 adds: --security-opt label=disable (the ro-bound roster secret carries a
# host SELinux label a confined candidate cannot read on the enforcing gate host — the exact
# FENCE_xrdp rationale; production runs SecurityLabelDisable=true) + NET_BIND_SERVICE + SYS_CHROOT
# (the A8 sshd door binds privileged :22 and privsep-chroots — identical to xrdp's WP-13 pair;
# grd's own RDP/VNC ports are >1024 and need neither).
FENCE_grd="--systemd=always --cgroupns=host -v /sys/fs/cgroup:/sys/fs/cgroup:rw --device /dev/fuse --security-opt label=disable --cap-add SETUID --cap-add SETGID --cap-add SETPCAP --cap-add CHOWN --cap-add FOWNER --cap-add FSETID --cap-add DAC_OVERRIDE --cap-add KILL --cap-add NET_BIND_SERVICE --cap-add SYS_CHROOT"
# GNOME software-compositing is materially heavier than XFCE (V36): N provisioned users = N
# llvmpipe gnome-shell compositors + N grd daemons + N pipewire/wireplumber pairs.
MEMORY_grd="6g"
PIDS_grd="4096"
# WP-08 TIGHTENS the health bar (the promise the skeleton made): kd-health = systemd fully
# stable state (running|degraded) + load-bearing daemons + provision-complete + EVERY provisioned
# user's manager active AND grd's RDP door answering real TCP on the uid-derived fixed port + sshd.
HEALTH_grd='kd-health'
# SELF-DIAGNOSING probe (H4): kd-health + the D6 census (V19 positive: kadm/gw1/gw2 exact, 5
# exclusions absent) + per-user RDP listeners (kadm:3389 gw1:3390 gw2:3391) + asserts the VNC port
# (5900) is SHUT — native VNC is DISABLED on this GRD primary lineage (DESIGN §2 note (j): grd's
# headless VNC is stock-incompatible anon-TLS and crash-prone, so its backend is off; RDP is the
# native door). On failure prints its own evidence — never a blind RED.
PROBE_grd='kd-health && test $(id -u kadm) = 2000 && test $(id -u gw1) = 2001 && test $(id -u gw2) = 2002 && ! id -u gw3 2>/dev/null && ! id -u gw4 2>/dev/null && ! id -u gw5 2>/dev/null && timeout 3 bash -c "exec 3<>/dev/tcp/127.0.0.1/3389" && timeout 3 bash -c "exec 3<>/dev/tcp/127.0.0.1/3390" && timeout 3 bash -c "exec 3<>/dev/tcp/127.0.0.1/3391" && ! timeout 1 bash -c "exec 3<>/dev/tcp/127.0.0.1/5900" 2>/dev/null || { echo =state= ; systemctl is-system-running ; echo =failed= ; systemctl --failed --no-legend ; echo =user-managers= ; systemctl list-units "user@*" --no-legend 2>&1 ; echo =prestart= ; journalctl -b --no-pager 2>&1 | grep -aiE "session prestart|apply subprocess|kd-session-enable|remote-desktop.*(Fail|error|refus)|0x904|Mutter.RemoteDesktop" | tail -14 ; echo =ports= ; for p in 3389 3390 3391 5900 5901 5902 22 ; do timeout 1 bash -c "exec 3<>/dev/tcp/127.0.0.1/$p" 2>/dev/null && echo open $p || echo shut $p ; done ; exit 1 ; }'
# Poll budget 40×6 = 240s. The bare skeleton needed ~60s on the shared-vCPU host; the full GNOME
# stack (3 users × gnome-shell-on-llvmpipe + grd + pipewire, provisioning first) is materially
# heavier (V36). F2: the budget must exceed the real first boot — re-measure at the gate and trim.
HEALTH_TRIES_grd="40"
HEALTH_SLEEP_grd="6"

# ---- LINEAGE 3: web (the ONE public door; DESIGN §3, WP-10) ---------------------------------
# The Guacamole gateway: Caddy :443 -> Tomcat 9 (guacamole webapp) -> guacd (vendored FreeRDP
# 3.14). bash PID 1 (kd-entrypoint), like xrdp. WP-02: boots a REAL PROVISIONED box (roster-mixed.json
# via SECRET_ENV → /run/secrets/kd-roster) — kd-provision → kd-web-sync writes the web identities
# + per-user desktop tiles; STRICT E2 means a rosterless boot is a RED (web_negsec, PR 3). The gate's
# truthful bar is kd-health's TWO legs (N4/N5): (1) an UNAUTHENTICATED API GET proves
# Caddy(TLS) -> Tomcat -> webapp servlet (200, zero auth failures — never self-bans, A4/WD-#11;
# /api/languages serves classpath resources, so it proves NOTHING about the DB); (2) a real
# `SELECT 1` on guacamole_db over the unix socket proves postgres answers queries. The live
# per-user TOTP round-trip (A3/A4/A11) is a MANUAL/browser tier above the gate (disclosed E6)
# — not asserted here.
CFILE_web="lineage-web/Containerfile"
SECRET_MOUNT_web="/run/secrets/kd-roster"
SECRET_ENV_web='{"version":1,"box":{"tailnet_authkey":"tskey-fixture-not-a-real-key","endpoints":{"erebus":{"host":"erebus.tail.fixture","port":22,"user":"core"},"fedora-dev":{"host":"fedora-dev.tail.fixture","port":22,"user":"core"}},"shared_folder":true},"admin":{"username":"kadm","password":"adm-aaaa-0000","ssh_authorized_keys":["ssh-ed25519 AAAAfixtureKEYadm fixture@kd"],"tiles":["erebus","fedora-dev"]},"workers":[{"username":"gw1","password":"gw1-bbbb-1111","ssh_authorized_keys":["ssh-ed25519 AAAAfixtureKEYgw1 fixture@kd"],"tiles":["erebus"]},{"username":"gw2","password":"gw2-cccc-2222"},{"username":"gw3","password":"not-the-a13-shape-at-all"},{"username":"gw1","password":"dup-dddd-3333"},{"username":"root","password":"sys-eeee-4444"},{"username":"gw4","password":"gw4-ffff-5555","color":"mauve"},{"username":"gw5","password":"gw5-gggg-6666","tiles":["mars"]}]}'
# Cap add-backs over the gate's --cap-drop=ALL floor (all userns-scoped, a subset of podman's own
# defaults — the same discipline as FENCE_grd). The web door is bash-PID-1 (NO systemd), so it needs
# NONE of grd's cgroup/systemd fence — only the caps its services genuinely use:
#   SETUID/SETGID/SETPCAP  runuser drops root→kdweb (postgres REFUSES to run as root; guacd + Tomcat
#                          also run as kdweb)
#   CHOWN                  the entrypoint mkdirs /run/postgresql (postgres' socket dir, absent
#                          without systemd-tmpfiles) and chowns it to kdweb
#   NET_BIND_SERVICE       Caddy (root) binds the :443 public door (A2) — a privileged port
#   DAC_OVERRIDE           shadow-utils (groupadd/useradd in the WP-11 provisioning boot path)
#                          write root's OWN 0000-mode /etc/{g,}shadow — the same-uid DAC bypass
#                          IS userns-effective and REQUIRED there. (The earlier "deliberately NOT
#                          added" note over-generalized the verified finding, which is narrower:
#                          DAC_OVERRIDE cannot bridge CROSS-uid writes in the rootless userns —
#                          so cross-uid file writes still run AS their owner, needing no cap.)
FENCE_web="--security-opt label=disable --cap-add SETUID --cap-add SETGID --cap-add SETPCAP --cap-add CHOWN --cap-add NET_BIND_SERVICE --cap-add DAC_OVERRIDE"
HEALTH_web='kd-health'
# self-diagnosing (H4): a RED carries its own evidence — boot markers, the service census, guacd's
# loopback door, and the deep-liveness HTTP code with the service logs that explain a non-200.
# Connection census (WP-14): the standard roster-mixed fixture provisions 3 users (kadm+gw1+gw2)
# → 3 DESKTOP tiles, PLUS the fleet SSH tiles from their grants (kadm→erebus+fedora-dev, gw1→erebus,
# gw2 none) → 3 SSH tiles. The probe asserts the BREAKDOWN (3 desktop + 3 fleet tiles), proving
# WP-14 actually wired the granted tiles — not a bare total a wrong-shaped row could still satisfy.
# No SQL string literals / single quotes (the value is single-quote-delimited + bash-exec'd in the
# candidate): the connection_name substrings "desktop" and "tile-" are non-overlapping, so grep -c
# on the name list is an exact, quote-free census.
PROBE_web='kd-health && names=$(runuser -u kdweb -- psql -h /run/postgresql -d guacamole_db -qtAX -c "select connection_name from guacamole_connection") && test $(printf "%s\n" "$names" | grep -c desktop) = 3 && test $(printf "%s\n" "$names" | grep -c tile-) = 3 || { echo =run-kd: ; ls -la /run/kd 2>&1 ; echo =web-users: ; runuser -u kdweb -- psql -h /run/postgresql -d guacamole_db -qtAX -c "select e.name from guacamole_user u join guacamole_entity e on u.entity_id=e.entity_id" 2>&1 ; echo =conns: ; runuser -u kdweb -- psql -h /run/postgresql -d guacamole_db -qtAX -c "select protocol,connection_name from guacamole_connection order by 1,2" 2>&1 ; echo =tomcat-tail: ; tail -12 /run/kd/tomcat.log 2>&1 ; exit 1 ; }'
# First boot runs initdb + guac schema load + Tomcat webapp expansion (genuinely slow on the
# shared-vCPU host): 30×6 = 180s budget, well past the ~60-90s real first boot (F2 — a slow first
# boot must never read as unhealthy; the grd lesson: budget must exceed the real first boot).
HEALTH_TRIES_web="30"
HEALTH_SLEEP_web="6"

# ---- SPIKE-TRANSIENT: grdgeom (WP-12 V2 gate-keeper) — REMOVE before the WP-12 build PR --------
# V2 (DESIGN V-register): can Mutter's ApplyMonitorsConfig force a common mode across grd's virtual
# monitors, and does Stop() detach — the L1 geometry-governor's C4-concurrent primitive? The
# candidate is the REAL provisioned grd box (systemd PID 1; kadm uid 2000). This ITERATION is a
# DIAGNOSTIC: it connects an RDP client (freerdp on Xvfb) to grd:3389 so Mutter creates a virtual
# monitor, then queries DisplayConfig.GetCurrentState to see what Mutter exposes. Later iterations
# drive ApplyMonitorsConfig + Stop(). RED-with-evidence; the decisive line rides /proc/1/fd/1.
CFILE_grdgeom="lineage-grd/Containerfile"
SECRET_MOUNT_grdgeom="/run/secrets/kd-roster"
SECRET_ENV_grdgeom='{"version":1,"box":{"tailnet_authkey":"tskey-fixture-not-a-real-key","endpoints":{"erebus":{"host":"erebus.tail.fixture","port":22,"user":"core"},"fedora-dev":{"host":"fedora-dev.tail.fixture","port":22,"user":"core"}},"shared_folder":true},"admin":{"username":"kadm","password":"adm-aaaa-0000","ssh_authorized_keys":["ssh-ed25519 AAAAfixtureKEYadm fixture@kd"],"tiles":["erebus","fedora-dev"]},"workers":[{"username":"gw1","password":"gw1-bbbb-1111","ssh_authorized_keys":["ssh-ed25519 AAAAfixtureKEYgw1 fixture@kd"],"tiles":["erebus"]},{"username":"gw2","password":"gw2-cccc-2222"},{"username":"gw3","password":"not-the-a13-shape-at-all"},{"username":"gw1","password":"dup-dddd-3333"},{"username":"root","password":"sys-eeee-4444"},{"username":"gw4","password":"gw4-ffff-5555","color":"mauve"},{"username":"gw5","password":"gw5-gggg-6666","tiles":["mars"]}]}'
FENCE_grdgeom="--systemd=always --cgroupns=host -v /sys/fs/cgroup:/sys/fs/cgroup:rw --device /dev/fuse --security-opt label=disable --cap-add SETUID --cap-add SETGID --cap-add SETPCAP --cap-add CHOWN --cap-add FOWNER --cap-add FSETID --cap-add DAC_OVERRIDE --cap-add KILL --cap-add NET_BIND_SERVICE --cap-add SYS_CHROOT"
MEMORY_grdgeom="6g"
PIDS_grdgeom="4096"
HEALTH_grdgeom='kd-health'
# The gate surfaces PID-1 stdout on RED, not the probe's — so the decisive V2-DIAG rides /proc/1/fd/1
# (one line, logs tr-joined with ~). rdptail shows whether the RDP client attached; mutter shows what
# DisplayConfig.GetCurrentState exposes (the virtual monitor grd created for the connection).
PROBE_grdgeom='kd-health || { echo V2-HEALTH-FAIL ; exit 1 ; } ; U(){ runuser -u kadm -- env HOME=/home/kadm XDG_RUNTIME_DIR=/run/user/2000 DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/2000/bus "$@" ; } ; GCS(){ U gdbus call --session --dest org.gnome.Mutter.DisplayConfig --object-path /org/gnome/Mutter/DisplayConfig --method org.gnome.Mutter.DisplayConfig.GetCurrentState 2>&1 ; } ; Xvfb :99 -screen 0 1400x1050x24 >/dev/null 2>&1 & sleep 3 ; DISPLAY=:99 xfreerdp /v:127.0.0.1:3389 /u:kadm /p:adm-aaaa-0000 /cert:ignore /size:1400x1050 /gdi:sw -gfx -clipboard /bpp:16 /log-level:WARN >/tmp/rdp.log 2>&1 & RP=$! ; for i in $(seq 1 60); do S=$(GCS) ; [ ${#S} -gt 250 ] && break ; sleep 0.3 ; done ; RES=$(U bash -c "echo  | base64 -d | python3" 2>&1 | tr "\n" "~") ; RT=$(tail -3 /tmp/rdp.log 2>&1 | tr "\n" "~") ; echo "V2-RESULT $RES rdptail=[$RT]" ; kill $RP 2>/dev/null ; exit 1'
HEALTH_TRIES_grdgeom="40"
HEALTH_SLEEP_grdgeom="6"
