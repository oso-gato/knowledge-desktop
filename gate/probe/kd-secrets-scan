#!/usr/bin/env bash
# kd-secrets-scan <secret1> [secret2 ...]  (WP-20 gate probe; E1) — proves NO roster secret VALUE
# leaked into a LOG, an ARGV, or a process ENV on the running provisioned box. E1 = "no secret in
# any layer, commit, argv, or log; roster material enters only via the podman secret." Roster
# material legitimately lives in the podman secret at /run/secrets/kd-roster — that is NOT a leak
# and is out of scope: this scans the LOGS + every process's cmdline/environ, never the sanctioned
# secret mount. RC-EXACT + self-diagnosing (the kd-vnc-check discipline). The caller (.live-gate
# PROBE) passes the PROVISIONED fixture phrases + the tailnet authkey — the values that flow through
# provisioning and could leak; a genuine secret never enters this box, so this is fixture-only.
#
#   exit 0 = zero hits (E1 holds)
#   exit 1 = a secret LEAKED into a log/argv/env (a real gate RED; self-diagnosing WHERE)
#   exit 2 = usage error
set -u
[ $# -ge 1 ] || { echo "usage: kd-secrets-scan <secret> [secret ...]" >&2; exit 2; }
tmp="$(mktemp)"; trap 'rm -f "$tmp"' EXIT
printf '%s\n' "$@" > "$tmp"          # grep -F -f fixed-string patterns, one secret per line

leak=0
# check runs in the MAIN shell (NOT the RHS of a pipe — that is a subshell, where `leak=1` would be
# lost; proven in-box: a piped report detected a leak yet the probe still exited 0). The scan output
# is captured to a var first, then grepped here.
check(){ # <where> <text-to-scan>
    local where="$1" lines
    lines="$(grep -F -f "$tmp" 2>/dev/null <<<"$2" | head -5)"
    if [ -n "$lines" ]; then
        echo "kd-secrets-scan: E1 LEAK — a roster secret appears in $where:" >&2
        printf '%s\n' "$lines" | sed 's/^/    /' >&2   # fixture value; a leak must be shown to diagnose
        leak=1
    fi
}

# This probe's OWN process ancestry (self + parents up to init) is TEST machinery, NOT the product:
# the gate PROBE passes the fixture secrets to this scanner as ARGV, so the scanner's own cmdline
# AND its parent PROBE-shell's cmdline necessarily contain them. E1 governs the PRODUCT's processes
# (kd-provision + the door services), so EXCLUDE the ancestry — else the scan self-matches and every
# run false-REDs. (Proven in-box: without this, scanning for a value passed on argv finds itself.)
# Skip the probe's OWN invocation machinery — THIS scanner, the .live-gate PROBE shell that calls
# it, and any harness wrapper — which legitimately hold the fixture secret because they INVOKE this
# scanner with it on their command line. Identify them by the probe's own name in their cmdline:
# robust across the gate (root, full /proc) and any test harness, with NO fragile ancestry-climb
# (that breaks at a uid boundary where /proc/<parent>/status is unreadable). Product processes
# (kd-provision, chpasswd, the door services) never reference this probe, so a genuine leak into
# THEIR argv/env is still caught.
scan_proc(){ # <cmdline|environ>
    local which="$1" f pid cmd
    for f in /proc/[0-9]*/"$which"; do
        pid="${f#/proc/}"; pid="${pid%/$which}"
        cmd="$(tr '\0' ' ' < "/proc/$pid/cmdline" 2>/dev/null)"
        case "$cmd" in *kd-secrets-scan*) continue;; esac
        cat "$f" 2>/dev/null | tr '\0' '\n'
    done
}

# 1. LOGS — the systemd journal (grd/PID-1) AND the entrypoint logs (xrdp/web are bash-PID-1, no
#    journald; their services log to /run/kd/*.log). kd-provision redacts phrases; this verifies it.
check "a LOG (journal / /run/kd/*.log — E1: no secret in a log)" \
    "$( { journalctl -b --no-pager 2>/dev/null; cat /run/kd/*.log 2>/dev/null; } )"

# 2. ARGV — no PRODUCT process command line holds a secret (E1: "rides STDIN only, never argv").
check "a process ARGV (/proc/*/cmdline)" "$(scan_proc cmdline)"

# 3. ENV — no PRODUCT process environment holds a secret (E1: secrets never in env; podman secret only).
check "a process ENV (/proc/*/environ)" "$(scan_proc environ)"

[ "$leak" -eq 0 ] || exit 1
echo "kd-secrets-scan: E1 GREEN — no roster secret in the journal/entrypoint logs, any argv, or any process env ($# values scanned)"
