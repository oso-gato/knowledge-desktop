# knowledge-desktop — LINEAGE 2: GRD / Wayland / GNOME (DESIGN.md §2)
# WP-01 SKELETON: systemd-PID-1 from the first commit — this lineage's init contract is
# structural (per-user lingering user managers; DESIGN §2), and the nested dev engine cannot
# boot PID-1 systemd, so ALL runtime proof for this lineage is host-gate tier (CLAUDE.md).
# The GNOME/GRD stack lands per BUILDPLAN (WP-08 onward). Base digest-pinned (N1).
ARG FEDORA_DIGEST=sha256:dde4f63cf8b0f57ffb62fe16b32ced482d17a9a0ea97f8f532caf387a108afc2
FROM registry.fedoraproject.org/fedora@${FEDORA_DIGEST}

# MINIMAL by design (N2): the skeleton installs ONLY systemd. There is no D-Bus consumer at this
# stage — GNOME, gnome-remote-desktop, and systemd-logind (the per-user lingering managers) all
# arrive with the desktop stack at WP-08, and dbus-broker lands THEN, as a deliberate design
# choice justified by those consumers. Installing it now would be a package with no consumer.
# The skeleton's honest claim is only "systemd-PID-1 boots to a terminal state" — the .live-gate
# HEALTH accepts running|degraded accordingly (a bare skeleton's statically-wanted logind unit
# fails for lack of its stack; that is expected, not a defect, until WP-08 tightens HEALTH to running).
RUN dnf -y --setopt=install_weak_deps=False install systemd && dnf clean all

ENTRYPOINT ["/sbin/init"]
STOPSIGNAL SIGRTMIN+3
