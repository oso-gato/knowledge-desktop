# knowledge-desktop — LINEAGE 2: GRD / Wayland / GNOME (DESIGN.md §2)
# WP-01 SKELETON: systemd-PID-1 from the first commit — this lineage's init contract is
# structural (per-user lingering user managers; DESIGN §2), and the nested dev engine cannot
# boot PID-1 systemd, so ALL runtime proof for this lineage is host-gate tier (CLAUDE.md).
# The GNOME/GRD stack lands per BUILDPLAN (WP-08 onward). Base digest-pinned (N1).
ARG FEDORA_DIGEST=sha256:dde4f63cf8b0f57ffb62fe16b32ced482d17a9a0ea97f8f532caf387a108afc2
FROM registry.fedoraproject.org/fedora@${FEDORA_DIGEST}

# MINIMAL by design (N2): the skeleton installs ONLY the systemd package. Note that systemd-logind
# ships INSIDE that package (its binary + the statically-wanted `multi-user.target.wants/
# systemd-logind.service`), so logind is already present and statically started at skeleton stage.
# What is NOT present is a system bus: dbus-broker is not installed (it is only a weak Recommends of
# systemd, so `install_weak_deps=False` never pulls it), so logind cannot reach a bus and fails /
# hits its start limit. That is EXPECTED at this stage, not a defect — the box still reaches a
# terminal init state, just `degraded` (one failed unit) rather than `running`, which is exactly
# why the .live-gate HEALTH accepts running|degraded here (and still rejects starting|offline).
# dbus-broker — together with the GNOME / gnome-remote-desktop stack that gives the bus a real set
# of consumers — lands at WP-08, which re-tightens HEALTH back to `running`. Installing dbus-broker
# NOW, ahead of the consumers that need the bus, would be a package installed before its purpose (N2).
RUN dnf -y --setopt=install_weak_deps=False install systemd && dnf clean all

# WP-06: kd-provision core — shipped INERT (the unit is NOT enabled, so skeleton boot/gate
# are unchanged); WP-08 enables it with the GRD stack + python3 (see kd-provision.service).
COPY shared/kd-provision              /usr/libexec/kd/kd-provision
COPY lineage-grd/kd-cred              /usr/libexec/kd/kd-cred
COPY lineage-grd/kd-provision.service /usr/lib/systemd/system/kd-provision.service
RUN chmod 0755 /usr/libexec/kd/kd-provision /usr/libexec/kd/kd-cred

ENTRYPOINT ["/sbin/init"]
STOPSIGNAL SIGRTMIN+3
