# knowledge-desktop — LINEAGE 2: GRD / Wayland / GNOME (DESIGN.md §2)
# WP-01 SKELETON: systemd-PID-1 from the first commit — this lineage's init contract is
# structural (per-user lingering user managers; DESIGN §2), and the nested dev engine cannot
# boot PID-1 systemd, so ALL runtime proof for this lineage is host-gate tier (CLAUDE.md).
# The GNOME/GRD stack lands per BUILDPLAN (WP-08 onward). Base digest-pinned (N1).
ARG FEDORA_DIGEST=sha256:dde4f63cf8b0f57ffb62fe16b32ced482d17a9a0ea97f8f532caf387a108afc2
FROM registry.fedoraproject.org/fedora@${FEDORA_DIGEST}

# dbus-broker — the system D-Bus broker. Design-sanctioned for this lineage (DESIGN §2): GNOME +
# systemd-logind (the per-user lingering managers depend on it) require a system bus; it is the
# same broker lineage-xrdp installs (DESIGN §1). N2 justification: logind, statically wanted by
# multi-user.target, cannot reach `running` without a bus, so a systemd-PID-1 image needs it now.
# NOTE ON THE FIX HISTORY: the boot only reaches `running` because the .live-gate FENCE grants the
# capability set (SETUID/SETGID/SETPCAP/CHOWN/... ) that dbus-broker's `User=dbus` transition needs
# under the gate's --cap-drop=ALL floor. The broker's PRESENCE alone does not fix the boot — the
# fence caps do; the two are complementary. (Corrects an earlier claim that installing the broker
# was itself the fix.)
RUN dnf -y --setopt=install_weak_deps=False install systemd dbus-broker && dnf clean all

ENTRYPOINT ["/sbin/init"]
STOPSIGNAL SIGRTMIN+3
