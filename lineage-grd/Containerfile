# knowledge-desktop — LINEAGE 1 (primary): GRD / Wayland / GNOME (DESIGN.md §2)
# WP-08 WALKING SKELETON: a real headless GNOME desktop image — per-user lingering
# `systemd --user` managers each running `gnome-shell --headless` (Wayland, llvmpipe software
# rendering) + `gnome-remote-desktop-headless` serving RDP+VNC on per-user fixed ports; systemd
# PID 1; kd-provision ENABLED at boot (strict E2). Base digest-pinned (N1).
#
# DESIGN-RECONCILE NOTES (§2 deviations, recorded in DESIGN.md with this PR):
#   * NO gnome-session: `gnome-shell --headless --mode=user` IS the session manager here —
#     gnome-session adds autostart machinery that fights the linger-only model (source-verified
#     against gnome-remote-desktop 50 + the reference headless-GNOME-over-RDP recipe).
#   * NO Xwayland: the toolset is pure-Wayland; mutter neither Requires nor Recommends it.
#   * NO mesa-vulkan-drivers: GTK4 is forced onto llvmpipe GL via GSK_RENDERER=gl
#     (/etc/environment.d/30-kd-display.conf). Named fallback: if apps crash VK_ERROR_DEVICE_LOST
#     at the gate, add mesa-vulkan-drivers (lavapipe) — one line.
#   * NO gnome-keyring/GDM/libva (DESIGN §2: headless file-backend creds; GPU encode not required).
#
# Package justifications (N2 — capability-relative minimalism, weak deps off):
#   systemd               PID 1 (ships systemd-logind statically wanted)
#   systemd-pam           pam_systemd.so — the ONLY thing that sets $XDG_RUNTIME_DIR + registers
#                         the logind `manager`-class session for a lingering user@UID manager.
#                         MANDATORY-EXPLICIT (second weak-dep landmine, same species as dbus-broker):
#                         only a Recommends of systemd, so weak-deps-off drops it; the PAM stack then
#                         skips its `-session optional pam_systemd.so` line SILENTLY (leading `-` =
#                         "skip if the .so can't load, don't even log") → user@UID starts env-less →
#                         "Trying to run as user instance, but $XDG_RUNTIME_DIR is not set" and every
#                         per-user manager dies. Its absence is why #23's first host boot went RED.
#   dbus-broker           the system bus (logind) + per-user session bus at /run/user/$UID/bus.
#                         MANDATORY-EXPLICIT: only a weak Recommends of systemd, so weak-deps-off
#                         never pulls it — its absence is why the WP-01 skeleton sat `degraded`
#   gnome-shell           the leaf: headless Wayland compositor + session manager; hard-pulls
#                         mutter, gjs, gnome-settings-daemon, the xdg portals, dconf
#   gnome-remote-desktop  the RDP door (grdctl + per-user headless daemon; the VNC backend is
#                         DISABLED on this lineage — §2 note (j)); hard-pulls
#                         pipewire, libei, freerdp-libs
#   wireplumber           pipewire session manager — PINNED EXPLICIT: the pipewire-session-manager
#                         virtual has TWO providers and grd's screencast dies (0x904) if dnf
#                         resolves the deprecated pipewire-media-session instead
#   nautilus              file management (B1)
#   mesa-dri-drivers      llvmpipe swrast/kms_swrast — software surfaceless EGL for mutter + grd
#                         (V16: no /dev/dri required)
#   xdg-user-dirs         ~/Documents etc — no gnome-session autostart exists to create them
#   openssl               per-user RDP TLS cert generation (grd RDP will not bind without cert+key)
#   python3               kd-provision runtime (WP-06)
#   python3-gobject       gi.repository.Gio for the WP-12 geometry-governor (Mutter DisplayConfig
#                         ApplyMonitorsConfig — C4); gdbus's text parser can't build the nested variant
#   shadow-utils          useradd/usermod/chpasswd + newuidmap/newgidmap (provisioning; B3 bands)
#   acl                   setfacl — the D4 shared-folder default ACL
#   procps-ng             pgrep — kd-health process liveness (F2)
#   glibc-langpack-en     UTF-8 locale
#   openssh-server mosh tmux   the A8 terminal door (key-only sshd + roaming mosh + the one
#                         persistent tmux session; lineage-agnostic, mirrors WP-13 L1)
#   podman crun passt fuse-overlayfs   B3 nested rootless podman (fuse-overlayfs PINNED, [ADJ-12])
#   git-core gh           WP-13 agents (kd-agent-env) + E4 vault git ops — named explicitly
#                         (weak deps off; the toolset layer installs neither)
ARG FEDORA_DIGEST=sha256:dde4f63cf8b0f57ffb62fe16b32ced482d17a9a0ea97f8f532caf387a108afc2
FROM registry.fedoraproject.org/fedora@${FEDORA_DIGEST}

# HEAVY/STABLE-EARLY (churn balance): the dnf layer
RUN dnf -y --setopt=install_weak_deps=False install \
        systemd systemd-pam dbus-broker \
        gnome-shell gnome-remote-desktop wireplumber \
        nautilus mesa-dri-drivers xdg-user-dirs openssl \
        python3 python3-gobject shadow-utils acl procps-ng glibc-langpack-en \
        openssh-server mosh tmux \
        podman crun passt fuse-overlayfs \
        git-core gh \
    && dnf clean all

# ---- systemd unit graph: per-user headless GNOME + grd, boot-enabled -------------------------
# gnome-shell-headless.service: the per-user headless Wayland compositor (systemd --user unit).
# grd-headless-override.conf: wires the SHIPPED gnome-remote-desktop-headless.service to the
#   compositor + pipewire, gives it a default.target [Install] (so --global enable auto-starts it
#   per user), and adds Restart=on-failure self-heal. grd MUST auto-start: `grdctl --headless enable`
#   configures a *running* daemon (grd-50 --help: "headless daemon running on a user session"), so
#   kd-session-enable's grdctl config would fail with no daemon. The T1.1 unconfigured-start problem
#   is instead fixed by kd-session-enable ending in `restart` (a config re-read), not `start` (no-op).
# environment.d: session identity + the llvmpipe/GL display env for EVERY user manager.
# user-cgroup-fix: defensive drop-in for the F44 systemd-259 user@.service cgroup EBUSY (#41278).
COPY lineage-grd/gnome-shell-headless.service  /etc/systemd/user/gnome-shell-headless.service
COPY lineage-grd/kd-geometry-governor.service  /etc/systemd/user/kd-geometry-governor.service
COPY lineage-grd/grd-headless-override.conf    /etc/systemd/user/gnome-remote-desktop-headless.service.d/override.conf
COPY lineage-grd/environment.d-20-session.conf /etc/environment.d/20-kd-session.conf
COPY lineage-grd/environment.d-30-display.conf /etc/environment.d/30-kd-display.conf
COPY lineage-grd/user-cgroup-fix.conf          /etc/systemd/system/user@.service.d/99-cgroup-fix.conf
COPY lineage-grd/user-xdg-runtime-dir.conf     /etc/systemd/system/user@.service.d/50-xdg-runtime-dir.conf
COPY lineage-grd/kd-provision.service          /usr/lib/systemd/system/kd-provision.service
# gdm is a HARD Requires of Fedora's gnome-shell (verified: the only closure member requiring it
# — an irreducible hard-dependency closure item, Principle 3: accepted + DISCLOSED). The design's
# "GDM stays out" is re-scoped to "GDM never RUNS": mask it + default to multi-user.target (this
# seatless lineage has no system graphical session — the per-user headless sessions ride the
# lingering user managers). Unmasked, gdm would fail on the missing seat and flunk kd-health's
# zero-failed-units bar.
# Mask the desktop-IRRELEVANT daemons that CANNOT run in this rootless no-CAP_SYS_ADMIN container
# (they only crash-loop + clutter). This is CLEANLINESS/minimalism, working WITH the honest health
# bar (kd-health tier-1 no longer counts failed units — it tolerates incidental degradation and
# proves door health by PROBING the doors). Two reasons masking still earns its place: (1) a masked
# dbus-activated unit returns a clean "unit is masked" to its caller instead of a crash-loop that
# spams the journal + sits `--failed`; (2) empirically the last container that stayed UP the full
# 240s health window (#23 @4a4bec0) had exactly this set masked — leaving colord/power-profiles
# UNMASKED (@5f8de43) coincided with an 8s exit=4, so keeping them masked is the known-stable config.
# The set — all irrelevant to headless RDP/VNC (no OOM/location/RT-audio/colour/power-panel matters):
#  - systemd-oomd (unit+socket): User=systemd-oom + sandboxing hard-fails CAP_SYS_ADMIN (systemd#34565).
#  - geoclue (location) + rtkit-daemon (RT scheduling — pipewire runs fine without it): FAILED @1431a6c.
#  - colord (display colour) + power-profiles-daemon: same gnome-shell-poked, container-incompatible class.
# polkit/upower are deliberately LEFT unmasked — the honest bar tolerates them and they are more
# load-bearing; masking them would be the whack-a-mole over-reach the tier-1 rewrite avoids.
# The dangling multi-user.target.wants/systemd-homed symlink (homed not installed) is removed for a clean audit.
RUN systemctl enable kd-provision.service sshd.service \
    && systemctl --global enable gnome-shell-headless.service gnome-remote-desktop-headless.service kd-geometry-governor.service \
    && systemctl set-default multi-user.target \
    && systemctl mask gdm.service systemd-oomd.service systemd-oomd.socket \
        geoclue.service rtkit-daemon.service colord.service power-profiles-daemon.service \
    && rm -f /etc/systemd/system/multi-user.target.wants/systemd-homed.service

# ---- A8 terminal door config (lineage-agnostic; reuses the L1-proven files verbatim) ---------
COPY lineage-xrdp/sshd-kd.conf /etc/ssh/sshd_config.d/10-kd.conf
COPY shared/kd-tmux.sh         /etc/profile.d/kd-tmux.sh
RUN chmod 0644 /etc/ssh/sshd_config.d/10-kd.conf /etc/profile.d/kd-tmux.sh \
    # fail-closed asserts (N4): the door is key-only and roots-out
    && grep -q '^PasswordAuthentication no' /etc/ssh/sshd_config.d/10-kd.conf \
    && grep -q '^PermitRootLogin no' /etc/ssh/sshd_config.d/10-kd.conf

# ================= TOOLSET (WP-15, B2) — identical to L1 except the terminal-default =========
# Provenance-classed per the tool-install hierarchy (class-a Fedora / class-b vendor gpg repo /
# class-c pinned download; NEVER COPR/curl|sh). Same set as lineage-xrdp (ONE toolset, two
# lineages): firefox(a) · ptyxis(a, made DEFAULT below via the GNOME dconf mechanism — NOT the
# XFCE exo-helpers file, which is L1-only) · code(b, Microsoft repo) · 1password/-cli(b) ·
# claude-code(b, Anthropic `latest`; DISABLE_UPDATES pins the dnf-managed binary, [ADJ-16]) ·
# Obsidian(c: official tar.gz, version+sha256 EXACT-pinned, fail-closed).
COPY shared/toolset/vendor-repos.sh /usr/local/libexec/kd-vendor-repos.sh
RUN chmod 0755 /usr/local/libexec/kd-vendor-repos.sh && /usr/local/libexec/kd-vendor-repos.sh \
    && dnf -y --setopt=install_weak_deps=False install \
        firefox ptyxis code 1password 1password-cli claude-code \
    && dnf clean all \
    && rm -f /usr/local/libexec/kd-vendor-repos.sh

# Obsidian (class-c): the URL + sha256 are the pin; a hash mismatch FAILS the build (fail-closed).
ARG OBSIDIAN_VERSION=1.12.7
ARG OBSIDIAN_SHA256=fcbe08b111d9c1fdb09b9c08952b06e1c829c62163eba2584c4b4ec859be079d
ADD https://github.com/obsidianmd/obsidian-releases/releases/download/v${OBSIDIAN_VERSION}/obsidian-${OBSIDIAN_VERSION}.tar.gz /tmp/obsidian.tar.gz
RUN set -eo pipefail \
    && echo "${OBSIDIAN_SHA256}  /tmp/obsidian.tar.gz" | sha256sum -c - \
    && mkdir -p /opt/obsidian \
    && tar xzf /tmp/obsidian.tar.gz -C /opt/obsidian --strip-components=1 \
    && ln -sf /opt/obsidian/obsidian /usr/local/bin/obsidian \
    && rm -f /tmp/obsidian.tar.gz \
    && test -x /opt/obsidian/obsidian \
    # Obsidian's tarball ships chrome-sandbox 0755 (VS Code + 1Password ship 4755) — without the
    # setuid bit Electron cannot use the SUID sandbox and would need --no-sandbox (V23 forbids it
    # "surfaced, never silent"). Set it setuid-root to match, giving Obsidian the same sandbox path.
    && chmod 4755 /opt/obsidian/chrome-sandbox

# Toolset config: Ptyxis as the GNOME default terminal (dconf system db compiled below — the
# GNOME mechanism, V24); Claude Code update-lock (managed settings); the Obsidian launcher.
COPY shared/toolset/claude-managed-settings.json /etc/claude-code/managed-settings.json
COPY shared/toolset/obsidian.desktop             /usr/share/applications/obsidian.desktop
COPY shared/toolset/kd-gnome-terminal.dconf      /etc/dconf/db/local.d/00-kd-terminal
COPY shared/toolset/kd-dconf-profile             /etc/dconf/profile/user
RUN dconf update

# Build-time assertions (N4 — a missing tool/unit FAILS the build, never a broken claim):
RUN set -e \
    && for b in firefox ptyxis code 1password obsidian; do command -v "$b" >/dev/null || { echo "TOOLSET MISSING: $b"; exit 1; }; done \
    && command -v op >/dev/null || { echo "TOOLSET MISSING: 1password-cli (op)"; exit 1; } \
    && test -x /usr/bin/claude || { echo "TOOLSET MISSING: claude at /usr/bin (dnf-managed)"; exit 1; } \
    && grep -q '"DISABLE_UPDATES": *"1"' /etc/claude-code/managed-settings.json \
    # every Electron app's SUID sandbox is setuid (V23: they start WITHOUT --no-sandbox) \
    && for s in /usr/share/code/chrome-sandbox /opt/1Password/chrome-sandbox /opt/obsidian/chrome-sandbox; do \
         [ -u "$s" ] || { echo "V23: $s is not setuid — Electron would need --no-sandbox"; exit 1; }; done \
    # L2-critical asserts: the GRD stack + the unit graph actually assembled \
    && command -v gnome-shell >/dev/null || { echo "L2 MISSING: gnome-shell"; exit 1; } \
    && command -v grdctl >/dev/null || { echo "L2 MISSING: grdctl — kd-cred/V17 cannot fire"; exit 1; } \
    && test -x /usr/bin/dbus-broker || { echo "L2 MISSING: dbus-broker (no system/session bus)"; exit 1; } \
    # the XDG_RUNTIME_DIR fix (#23 RED root cause): pam_systemd.so MUST exist or every lingering \
    # user@UID manager starts env-less and dies. weak-deps-off drops it unless named explicitly. \
    && ls /usr/lib64/security/pam_systemd.so >/dev/null 2>&1 || { echo "L2 MISSING: pam_systemd.so — user@UID would start without \$XDG_RUNTIME_DIR (systemd-pam not installed)"; exit 1; } \
    && grep -rq 'pam_systemd' /etc/pam.d/system-auth || { echo "L2: pam_systemd not wired into system-auth"; exit 1; } \
    && test -f /etc/systemd/system/user@.service.d/50-xdg-runtime-dir.conf || { echo "L2: XDG_RUNTIME_DIR drop-in missing"; exit 1; } \
    && for m in systemd-oomd geoclue rtkit-daemon colord power-profiles-daemon; do [ "$(readlink /etc/systemd/system/$m.service)" = "/dev/null" ] || { echo "L2: $m.service not masked — a container-incompatible unneeded daemon"; exit 1; }; done \
    && test -f /usr/lib/systemd/user/gnome-remote-desktop-headless.service || { echo "L2 MISSING: shipped grd headless user unit (override target)"; exit 1; } \
    && test -f /etc/dconf/db/local || { echo "L2: dconf db not compiled (ptyxis default, V24)"; exit 1; } \
    && test -L /etc/systemd/system/multi-user.target.wants/kd-provision.service || { echo "L2: kd-provision.service not enabled"; exit 1; } \
    && test -L /etc/systemd/system/multi-user.target.wants/sshd.service || { echo "L2: sshd.service not enabled (A8)"; exit 1; } \
    && test -L /etc/systemd/user/default.target.wants/gnome-shell-headless.service || { echo "L2: gnome-shell-headless not globally enabled"; exit 1; } \
    && [ "$(readlink /etc/systemd/system/default.target)" = "/usr/lib/systemd/system/multi-user.target" ] || { echo "L2: default target is not multi-user (seatless lineage)"; exit 1; } \
    && [ "$(readlink /etc/systemd/system/gdm.service)" = "/dev/null" ] || { echo "L2: gdm not masked — it would fail on the missing seat and flunk kd-health"; exit 1; } \
    && echo "L2 (WP-08) assembled: GNOME-headless + grd doors + toolset obsidian-${OBSIDIAN_VERSION}"

# CHURN-LATE: repo-owned glue (shared provisioning + the L2 hooks + the reused VNC probes).
# NOT copied: the Lineage-2 (XRDP) session glue (entrypoint-l1.sh, startwm-kd, doors-agent,
# xorg.conf, shared/kd-health [xrdp-hardcoded — this lineage's kd-health is its own file],
# kd-vault-driver) AND the VNC RFB probe tools (kd-vnc-login/kd-vnc-check) — this primary lineage
# serves NO native VNC (DESIGN §2 note (j): grd VNC disabled), so the RFB probe has no door to test.
# COPIED (unlike the VNC probes): kd-rdp-check — RDP is grd's native + ONLY door (per-user 3389/3390/
# 3391), so the C2 protocol-handshake proof (§6.2) runs here.
# DEFERRED: the vault trio (kd-vault-sync/init/gitignore) rides the WP-17 half (the per-user timer).
COPY shared/kd-provision            /usr/libexec/kd/kd-provision
COPY lineage-grd/kd-cred            /usr/libexec/kd/kd-cred
COPY lineage-grd/kd-session-enable  /usr/libexec/kd/kd-session-enable
COPY lineage-grd/kd-health          /usr/local/bin/kd-health
COPY shared/kd-agent-env            /usr/libexec/kd/kd-agent-env
COPY shared/kd-agent-run            /usr/libexec/kd/kd-agent-run
COPY gate/probe/kd-rdp-check        /usr/libexec/kd/kd-rdp-check
# WP-12 (C4): the geometry-governor + the kd-geometry oracle (both python3-gi; python3-gobject dep)
COPY lineage-grd/geometry-governor  /usr/libexec/kd/geometry-governor
COPY gate/probe/kd-isolation-check  /usr/libexec/kd/kd-isolation-check
COPY gate/probe/kd-secrets-scan     /usr/libexec/kd/kd-secrets-scan
COPY shared/kd-geometry             /usr/local/bin/kd-geometry
RUN chmod 0755 /usr/libexec/kd/kd-provision /usr/libexec/kd/kd-cred \
        /usr/libexec/kd/kd-session-enable /usr/local/bin/kd-health \
        /usr/libexec/kd/kd-agent-env /usr/libexec/kd/kd-agent-run \
        /usr/libexec/kd/kd-rdp-check \
        /usr/libexec/kd/geometry-governor /usr/local/bin/kd-geometry \
        /usr/libexec/kd/kd-isolation-check \
        /usr/libexec/kd/kd-secrets-scan

ENTRYPOINT ["/sbin/init"]
STOPSIGNAL SIGRTMIN+3
