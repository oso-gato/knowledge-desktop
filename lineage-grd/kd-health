#!/usr/bin/env bash
# kd-health (LINEAGE 2 — GRD/Wayland/GNOME, systemd PID 1; WP-08). The TRUTHFUL health authority
# (F2/N5): real process + real TCP answers, never a cached flag alone. Its own file — shared/
# kd-health is L1-hardcoded (xrdp-sesman/:3389/x0vncserver) and would falsely assert L1 daemons
# that do not exist here (an UNTRUE health claim, N4).
#
# Tiers:
#   1. INIT: systemd reached a STABLE state (running|degraded) AND the two LOAD-BEARING system
#      daemons are active — dbus-broker (the bus grd/logind ride) + systemd-logind (linger → the
#      per-user managers). This SUPERSEDES the WP-08 "zero failed units" tighten (the design's
#      OWN named-relaxation path, tier-3 note): empirically a full GNOME session in a rootless
#      no-CAP_SYS_ADMIN container ALWAYS leaves a tail of incidental system daemons failed
#      (polkit, upower, and the geoclue/rtkit/colord/power-profiles class we mask) — NONE of which
#      is what makes the DESKTOP healthy, and requiring zero-failed is unbounded whack-a-mole that
#      a Fedora update re-breaks. The REAL door/session health is proven positively by tiers 2-4
#      (each user@uid active + RDP/VNC ports answer) + PROBE_grd's port census — grd and gnome-shell
#      are USER services whose failures never even move the system-level is-system-running, so the
#      old system bar was never a door-health proxy anyway (N4/N5 honest: assert what MUST hold,
#      tolerate incidental degradation, prove the doors by probing them).
#   2. E2: provisioning completed (/run/kd/provision-complete — kd-provision is shared).
#   3. PER-USER DOORS (C3 warm sessions, unaided): for EVERY provisioned user (uid>=2000), the
#      lingering user@uid manager is active AND both grd doors answer a REAL TCP connect on the
#      uid-derived fixed ports (RDP 3389+off, VNC 5900+off — the [ADJ-34] arithmetic). Strict by
#      design; HealthStartPeriod covers the slow first GNOME boot. If the gate proves this too
#      brittle, the named relaxation is "≥1 user's doors answer" — recorded, not silent.
#   4. A8 SSH door: sshd alive + :22 answers.
set -u
fail(){ echo "kd-health: UNHEALTHY — $*"; exit 1; }

# 1. init authority is systemd itself — stable state + the load-bearing daemons (not every unit)
s="$(systemctl is-system-running 2>/dev/null)"
{ [ "$s" = running ] || [ "$s" = degraded ]; } || fail "system not up (is-system-running=$s)"
for u in dbus-broker.service systemd-logind.service; do
    systemctl is-active "$u" >/dev/null 2>&1 || fail "load-bearing unit down: $u"
done

# 2. provisioning completed (strict E2)
[ -f /run/kd/provision-complete ] || fail "provisioning never completed"

# 3. per-user doors
found=0
while IFS=: read -r name _ uid _; do
    [ "$uid" -ge 2000 ] 2>/dev/null || continue
    [ "$uid" -lt 60000 ] || continue
    found=1
    systemctl is-active "user@${uid}.service" >/dev/null 2>&1 || fail "user@${uid} (${name}) manager down"
    off=$(( uid - 2000 ))
    timeout 3 bash -c "exec 3<>/dev/tcp/127.0.0.1/$(( 3389 + off ))" 2>/dev/null || fail "no RDP answer for ${name} :$(( 3389 + off ))"
    timeout 3 bash -c "exec 3<>/dev/tcp/127.0.0.1/$(( 5900 + off ))" 2>/dev/null || fail "no VNC answer for ${name} :$(( 5900 + off ))"
done < <(getent passwd)
[ "$found" = 1 ] || fail "no provisioned users (uid>=2000)"

# 4. the A8 terminal door
pgrep -x sshd >/dev/null || fail "sshd not running (A8 door down)"
timeout 3 bash -c 'exec 3<>/dev/tcp/127.0.0.1/22' 2>/dev/null || fail "no answer on :22 (sshd)"

exit 0
