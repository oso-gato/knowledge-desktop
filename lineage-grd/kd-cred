#!/usr/bin/env bash
# kd-cred (LINEAGE 1 — GRD/Wayland/GNOME) — the per-lineage door-credential installer
# (DESIGN.md §4/§8; WP-06 core, WP-08 live). Driven ONLY by kd-provision; the ONE phrase arrives
# on STDIN (E1: never argv, never env). Door derivations on this lineage:
#   - Unix shadow (yescrypt via chpasswd) — SSH/console identity (A12)
#   - grd RDP store: the FULL phrase, via grdctl piped stdin (V17)
# NO grd VNC credential — native VNC is DROPPED on this lineage (DESIGN §2 note (j)); RDP is the
# door. The A13 first-8 VNC-truncation rule applies only to Lineage 2's (XRDP) VNC door.
# `revoke <user>` (D5): clears the grd RDP store (challenge US-#11's revoke verb).
#
# CREDENTIAL-ONLY BY DESIGN (the WP-08 pass split): this runs in kd-provision PASS 1 — BEFORE any
# linger, so the user has NO live session bus. `grdctl --headless … set-credentials/set-password`
# writes the GKeyFile store (~/.local/share/gnome-remote-desktop/credentials.ini) directly — no
# bus needed. Port/TLS/enable configuration hits dconf (which DOES need the live user bus) and
# therefore lives in kd-session-enable (pass 2), never here.
#
# V17 CONTINGENCY (named): if the host gate shows `grdctl set-credentials` refusing without a
# live session bus, the designed fallback is a direct GKeyFile write to
# ~<user>/.local/share/gnome-remote-desktop/credentials.ini ([RDP] / [VNC] groups — the same
# file the daemon reads). That settles V17 either way; record the outcome on the PR.
set -euo pipefail

usage(){ echo "usage: kd-cred install|revoke <user>  (install: phrase on stdin)" >&2; exit 2; }
[ $# -eq 2 ] || usage
verb="$1"; user="$2"

getent passwd "$user" >/dev/null || { echo "kd-cred: no such user (value-free)" >&2; exit 1; }
uid="$(id -u "$user")"

grd_as_user(){ # run grdctl AS the target user with a session-shaped env; the secret rides STDIN
    # -l gives grdctl a real HOME (the GKeyFile store lives under ~); the runtime-dir/bus vars
    # make pass-2-era invocations equivalent — in pass 1 the bus socket may not exist yet, which
    # is fine: the headless credential verbs use the file backend, not the bus. The phrase passes
    # through runuser's inherited stdin — never argv, never env (E1). Non-interactive `-c`, so
    # the A8 profile.d tmux attach (interactive-only guard) never fires.
    runuser -l "$user" -c "export XDG_RUNTIME_DIR=/run/user/${uid} DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/${uid}/bus; $*"
}

case "$verb" in
install)
    IFS= read -r phrase   # the one A13 phrase, stdin only (E1)
    [ -n "$phrase" ] || { echo "kd-cred: empty phrase on stdin" >&2; exit 1; }
    printf '%s:%s\n' "$user" "$phrase" | chpasswd
    if command -v grdctl >/dev/null; then
        # ensure the GKeyFile store dir exists BEFORE grdctl set-credentials — grd's headless
        # backend writes ~/.local/share/gnome-remote-desktop/credentials.ini, and that dir is
        # otherwise first created in kd-session-enable (pass 2, LATER). A grdctl g_file_set_contents
        # ENOENT here would throw up into kd-provision's apply_user => admin die(4) => exit-force
        # (a candidate for the observed 8s exit=4). Create it as the user so ownership is correct.
        grd_as_user 'mkdir -p "$HOME/.local/share/gnome-remote-desktop"'
        # V17: RDP credentials via piped stdin — never argv (E1). No VNC password: VNC is disabled.
        printf '%s\n' "$phrase"        | grd_as_user "grdctl --headless rdp set-credentials '$user'"
    else
        # WP-08 ships grdctl and the build ASSERTS it — its absence here is a broken image, and a
        # silent skip would ship doors with no credentials (an UNTRUE "provisioned" claim, N4).
        echo "kd-cred: grdctl absent — broken Lineage-1 image (the build asserts grdctl); failing the install" >&2
        exit 1
    fi
    ;;
revoke)
    if command -v grdctl >/dev/null; then
        grd_as_user "grdctl --headless rdp clear-credentials" || true
    else
        echo "kd-cred: grdctl absent — grd store revoke SKIPPED (nothing to clear on a grdctl-less image)" >&2
    fi
    ;;
*)  usage ;;
esac
